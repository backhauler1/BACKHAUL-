#
# Stage 1: Build Stage
# This stage installs all dependencies (including devDependencies) and runs the build script.
#
FROM node:18-alpine AS builder

WORKDIR /usr/src/app

# Copy package.json and package-lock.json to leverage Docker cache
COPY package.json package-lock.json* ./

# Install all dependencies
RUN npm ci

# Copy the rest of your application's source code
COPY . .

# Run the build script (e.g., for a React, Vue, or Angular frontend)
# If your project doesn't have a build step, you can remove this line.
RUN npm run build

#
# Stage 2: Production Stage
# This stage creates the final, lean production image.
#
FROM node:18-alpine AS production

WORKDIR /usr/src/app

# Create and use a non-root user for better security
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser

# Copy package files and install *only* production dependencies
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

# Copy the built assets and necessary source code from the builder stage
COPY --from=builder /usr/src/app/dist ./dist
COPY --from=builder /usr/src/app/src ./src

# Expose the port your application will run on
EXPOSE 3000

# The command to start your application in production
CMD ["node", "src/index.js"] # Or whatever your entry point is