# This file configures the services for your application on Render.
# Render will automatically detect this file and set up the environment.

services:
  # -----------------
  # Web Service (Your Node.js App)
  # -----------------
  - type: web
    name: food-truck-app
    runtime: docker
    # The Dockerfile is in the root, so Render will find it automatically.
    plan: free # Specifies the free instance type
    envVars:
      - key: NODE_ENV
        value: production
      - key: DATABASE_URL
        fromDatabase:
          name: food-truck-db
          property: connectionString
      - key: REDIS_URL
        fromService:
          type: redis
          name: food-truck-redis
          property: connectionString
      # IMPORTANT: Add other secrets like SECRET_KEY in the Render dashboard.

  # -----------------
  # Redis Cache
  # -----------------
  - type: redis
    name: food-truck-redis
    plan: free

databases:
  # -----------------
  # PostgreSQL Database
  # -----------------
  - name: food-truck-db
    plan: free