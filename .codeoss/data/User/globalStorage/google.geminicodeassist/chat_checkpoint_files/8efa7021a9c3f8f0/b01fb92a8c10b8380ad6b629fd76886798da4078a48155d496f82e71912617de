{# This macro helps avoid repeating the same card HTML. It's used on profile.html and dashboard.html #}
{% macro render_load_card(load, is_asap_view=False) %}
    <div class="card">
        <h3>{{ load.description }} (ID: {{ load.load_id }})</h3>
        {% if load.category %}
            <p><strong>Category:</strong> <span class="badge" style="background-color: var(--light-gray); padding: 3px 8px; border-radius: 12px; font-size: 0.85em; color: var(--text-dark);">{{ load.category }}</span></p>
        {% endif %}
        {% if load.package_size or load.dimensions or load.weight %}
            <p><strong>Size / Weight:</strong> 
                {% if load.package_size %}{{ load.package_size }}{% endif %}
                {% if load.dimensions %} [Exact: {{ load.dimensions }}]{% endif %}
                {% if load.weight %} - {{ load.weight }}{% endif %}
            </p>
        {% endif %}
        {% if load.image_filename %}
            <div class="load-image-container">
                <img src="{{ url_for('static', filename='uploads/' + load.image_filename) }}" alt="Image for {{ load.description }}">
            </div>
        {% endif %}
        <p><strong>Route:</strong> {{ load.pickup }} &rarr; {{ load.delivery }}</p>
        <p><strong>Shipping Date:</strong> {% if is_asap_view %}<span style="color: #dc3545; font-weight: bold;">{{ load.shipping_date }}</span>{% else %}{{ load.shipping_date }}{% endif %}</p>
        <p><strong>Offer:</strong> ${{ load.offer }}</p>
        {% if load.is_trailer %}
            <p><strong>Load Type:</strong> Trailer for Hauling</p>
            {% if load.requires_bol %}
                <p style="font-size: 0.85em; color: #d9534f; margin-top: 5px;">* Bill of Lading is required.</p>
            {% endif %}
        {% else %}
            <p><strong>Loading:</strong> {{ 'Driver to load' if load.loading_responsibility == 'driver' else 'Shipper provides equipment' }}</p>
            {% if load.equipment_failure_compensation %}
                <p style="font-size: 0.85em; color: #d9534f; margin-top: 5px;">* Shipper agrees to compensate for loading delays if equipment is unavailable.</p>
            {% endif %}
        {% endif %}
        {% if session.user_id == user.user_id %}
        <div class="card-actions">
            <a href="{{ url_for('edit_load', load_id=load.load_id) }}" class="btn">Edit</a>
            <form action="{{ url_for('delete_load', load_id=load.load_id) }}" method="POST" onsubmit="return confirm('Are you sure you want to delete this load?');">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
        {% elif session.user_id %}
        <div class="card-actions">
            <a href="{{ url_for('chat', other_user_id=user.user_id) }}" class="btn btn-success">Message Shipper</a>
            <button class="btn make-offer-btn" data-load-id="{{ load.load_id }}" data-load-description="{{ load.description }}">Make an Offer</button>
        </div>
    {% else %}
    <div class="card-actions">
        <a href="{{ url_for('login') }}" class="btn">Log in to Message or Make an Offer</a>
    </div>
        {% endif %}
        {% if caller %}
            {{ caller() }}
        {% endif %}
    </div>
{% endmacro %}

{% macro render_truck_card(truck, is_owner=False, show_transporter=False, show_map=False) %}
    <div class="card{% if show_map %} truck-card{% endif %}"
         {% if show_map %}
         data-departure="{{ truck.departure_city }}"
         data-destination="{{ truck.destination_city }}"
         data-vehicle-id="{{ truck.vehicle_id }}"
         {% endif %}>
        <h3>{{ truck.vehicle_type }} (ID: {{ truck.vehicle_id }})</h3>
        {% if truck.category %}
            <p><strong>Suited For:</strong> <span class="badge" style="background-color: var(--light-gray); padding: 3px 8px; border-radius: 12px; font-size: 0.85em; color: var(--text-dark);">{{ truck.category }}</span></p>
        {% endif %}
        {% if show_transporter %}
        <p><strong>Transporter:</strong> <a href="{{ url_for('profile', user_id=truck.driver_id) }}">{{ truck.username }}</a>
            {% if truck.id_verified %}<span class="badge" style="background-color: var(--success-color); color: var(--white); font-size: 0.7em; vertical-align: middle; padding: 3px 6px; border-radius: 10px; margin-left: 5px;">✓ ID Verified</span>{% endif %}
            {% if truck.rating_count is defined and truck.rating_count > 0 %}
                <span class="rating">★ {{ "%.2f"|format(truck.avg_rating) }} ({{ truck.rating_count }})</span>
            {% elif truck.rating_count is defined %}
                <span>(No reviews yet)</span>
            {% endif %}
        </p>
        {% endif %}
        <p><strong>Route:</strong> {{ truck.departure_city }} &rarr; {{ truck.destination_city }}</p>
        {% if show_map %}
        <div id="map-{{ truck.vehicle_id }}" class="map-container"></div>
        {% endif %}
        <p><strong>Availability:</strong> {{ truck.start_date }} to {{ truck.end_date }}</p>
        {% if truck.max_weight %}
        <p><strong>Max Capacity:</strong> {{ truck.max_weight }} lbs</p>
        {% endif %}
        {% if truck.max_dimensions %}
        <p><strong>Max Dimensions:</strong> {{ truck.max_dimensions }}</p>
        {% endif %}
        <p><strong>Equipment:</strong> {{ 'Has own loading equipment' if truck.has_loading_equipment else 'No loading equipment provided' }}</p>
        <p><strong>Hauling Capability:</strong> {{ 'Can haul a trailer (bobtailing)' if truck.can_haul_trailer else 'Not available for trailer hauling' }}</p>

        {% if is_owner %}
        <div class="card-actions">
            <a href="{{ url_for('edit_truck', vehicle_id=truck.vehicle_id) }}" class="btn">Edit</a>
            <form action="{{ url_for('delete_truck', vehicle_id=truck.vehicle_id) }}" method="POST" onsubmit="return confirm('Are you sure you want to delete this truck?');">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
        {% elif show_transporter and session.user_id and session.user_id != truck.driver_id %}
        <div class="card-actions">
            <a href="{{ url_for('chat', other_user_id=truck.driver_id) }}" class="btn btn-success">Message Transporter</a>
            <a href="{{ url_for('index') }}?vehicle_id={{ truck.vehicle_id }}#matchSection" class="btn">Request This Truck</a>
        </div>
        {% elif show_transporter and not session.user_id %}
        <div class="card-actions">
            <a href="{{ url_for('login') }}" class="btn">Log in to Request This Truck</a>
        </div>
        {% endif %}
    </div>
{% endmacro %}

{% macro render_bid_modal() %}
<!-- Bidding Modal -->
<div id="bidModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <h2>Make an Offer</h2>
        <p>For load: <strong id="modalLoadDescription"></strong></p>
        <form id="bidForm" style="margin-top: 20px;">
            <input type="hidden" id="modalLoadId" name="load_id">
            <label for="bidAmount">Your Offer Amount ($)</label>
            <input type="number" id="bidAmount" name="bid_amount" placeholder="e.g., 450" required min="1" style="margin-bottom: 15px;">
            <label for="bidMessage">Message to Shipper (optional)</label>
            <textarea id="bidMessage" name="message" rows="3" placeholder="e.g., I can pick this up tomorrow morning." style="margin-bottom: 15px;"></textarea>
            <button type="submit" class="btn">Submit Offer</button>
        </form>
        <div id="bidResult" class="result" style="margin-top: 15px;"></div>
    </div>
</div>
{% endmacro %}