<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat with {{ other_user.username }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <!-- Socket.IO client -->
    <script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
</head>
<body>
<div class="container">
    <a href="{{ url_for('inbox') }}" class="back-link">&larr; Back to Inbox</a>
    <h1>Chat with <a href="{{ url_for('profile', user_id=other_user_id) }}">{{ other_user.username }}</a></h1>

    <div class="chat-box" id="chatBox">
        {% if messages %}
            {% for msg in messages %}
                <div class="message {% if msg.sender_id == session.user_id %}sent{% else %}received{% endif %}">
                    {{ msg.content }}
                    <span class="time">{{ msg.timestamp|datetimeformat }}</span>
                </div>
            {% endfor %}
        {% else %}
            <p class="no-results" id="noMessages" style="padding: 20px 0;">No messages yet. Send one to start the conversation!</p>
        {% endif %}
    </div>

    <!-- The form no longer needs action/method, it will be handled by JS -->
    <form id="chatForm" class="chat-form">
        <input type="text" id="messageInput" placeholder="Type your message..." required autocomplete="off" autofocus>
        <button type="submit">Send</button>
    </form>
</div>

    <script src="{{ url_for('static', filename='main.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const currentUserId = {{ session.user_id }};
            const otherUserId = {{ other_user_id }};
            initializeChat(currentUserId, otherUserId);
        });
    </script>
</body>
</html>