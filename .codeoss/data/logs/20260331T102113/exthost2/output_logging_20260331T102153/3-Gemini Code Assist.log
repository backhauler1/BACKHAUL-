n# This stage creates the final, lean production image.\n#\nFROM node:18-alpine AS production\n\nWORKDIR /usr/src/app\n\n# Create and use a non-root user for better security\nRUN addgroup -S appgroup \u0026\u0026 adduser -S appuser -G appgroup\n\n# Copy package files and install *only* production dependencies\n# We'll do this as root, which is fine for a build step.\nCOPY package.json package-lock.json* ./\nRUN npm ci --omit=dev\n\n# Copy the built assets and necessary source code from the builder stage\nCOPY --from=builder /usr/src/app/dist ./dist\nCOPY --from=builder /usr/src/app/src ./src\n\n# Now, change ownership of all application files to the non-root user\nRUN chown -R appuser:appgroup /usr/src/app\n\n# Switch to the non-root user for execution\nUSER appuser\n\n# Expose the port your application will run on\nEXPOSE 3000\n\n# The command to start your application in production\nCMD [\"node\", \"src/index.js\"]","promptCitations":[{"startIndex":919,"endIndex":1139,"filepath":"/home/perrymckay1/Dockerfile"}],"telemetry":{"CommentLines":null},"codeBlockIndex":0,"language":"dockerfile","checkpointFile":"ba84283bac54365ad77832abe507c8a2c9fbafd3eb303df29b1273bf226f06c2","accepted":true}]},"fileUsage":{"includedFiles":["/home/perrymckay1/Dockerfile","/home/perrymckay1/package.json","/home/perrymckay1/.dockerignore","/home/perrymckay1/.config/powershell/Microsoft.PowerShell_profile.ps1","/home/perrymckay1/node_modules/buffer/package.json","/home/perrymckay1/build.yml","/home/perrymckay1/.codeoss/data/User/History/48b8dbe5/n3wb.yml","/home/perrymckay1/.codeoss/data/User/History/56ee5218/R9vE.yml","/home/perrymckay1/node_modules/readable-stream/lib/_stream_writable.js","/home/perrymckay1/node_modules/stream-browserify/node_modules/readable-stream/lib/_stream_writable.js","/home/perrymckay1/node_modules/readable-stream/lib/_stream_readable.js","/home/perrymckay1/node_modules/stream-browserify/node_modules/readable-stream/lib/_stream_readable.js","/home/perrymckay1/.cach