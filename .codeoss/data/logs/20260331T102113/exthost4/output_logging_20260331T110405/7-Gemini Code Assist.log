I0331 11:13:49.835674   18955 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didSave: {"textDocument":{"uri":"file:///home/perrymckay1/render.yaml"},"text":"# This file configures the services for your application on Render.\n# Render will automatically detect this file and set up the environment.\n\nservices:\n  # -----------------\n  # Web Service (Your Node.js App)\n  # -----------------\n  - type: web\n    name: food-truck-app\n    runtime: docker\n    # The Dockerfile is in the root, so Render will find it automatically.\n    plan: free # Specifies the free instance type\n    envVars:\n      - key: NODE_ENV\n        value: production\n      - key: DATABASE_URL\n        fromDatabase:\n          name: food-truck-db\n          property: connectionString\n      - key: REDIS_URL\n        fromService:\n          type: redis\n          name: food-truck-redis\n          property: connectionString\n      # IMPORTANT: Secrets like JWT_SECRET are added in the Render dashboard.\n      - key: JWT_SECRET\n        sync: false # This value is managed in the Render dashboard\n\n  # -----------------\n  # Redis Cache\n  # -----------------\n  - type: redis\n    name: food-truck-redis\n    plan: free\n\ndatabases:\n  # -----------------\n  # PostgreSQL Database\n  # -----------------\n  - name: food-truck-db\n    plan: free"}
