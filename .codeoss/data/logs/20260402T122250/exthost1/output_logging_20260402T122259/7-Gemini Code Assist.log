 }}\"\u003e\n            \u003cinput type=\"text\" name=\"destination_city\" placeholder=\"Destination City\" value=\"{{ truck.destination_city }}\"\u003e\n            \u003clabel for=\"start_date\"\u003eStart Date:\u003c/label\u003e\n            \u003cinput type=\"date\" name=\"start_date\" id=\"start_date\" value=\"{{ truck.start_date }}\" required\u003e\n            \u003clabel for=\"end_date\"\u003eEnd Date:\u003c/label\u003e\n            \u003cinput type=\"date\" name=\"end_date\" id=\"end_date\" value=\"{{ truck.end_date }}\" required\u003e\n            \u003cinput type=\"number\" name=\"max_weight\" placeholder=\"Max Weight (lbs)\" value=\"{{ truck.max_weight or '' }}\" min=\"0\"\u003e\n            \u003cinput type=\"text\" name=\"max_dimensions\" placeholder=\"Max Dimensions\" value=\"{{ truck.max_dimensions or '' }}\"\u003e\n            \u003cdiv class=\"checkbox-group\" style=\"margin-bottom: 15px; display: flex; align-items: flex-start; gap: 8px;\"\u003e\n                \u003cinput type=\"checkbox\" name=\"has_loading_equipment\" id=\"has_loading_equipment\" value=\"true\" {% if truck.has_loading_equipment %}checked{% endif %}\u003e\n                \u003clabel for=\"has_loading_equipment\" style=\"font-size: 0.85em; color: var(--text-secondary); margin-top: 2px; line-height: 1.4;\"\u003eI have my own loading equipment (e.g., ramps, liftgate, dolly).\u003c/label\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"checkbox-group\" style=\"margin-bottom: 15px; display: flex; align-items: flex-start; gap: 8px;\"\u003e\n                \u003cinput type=\"checkbox\" name=\"can_haul_trailer\" id=\"can_haul_trailer\" value=\"true\" {% if truck.can_haul_trailer %}checked{% endif %}\u003e\n                \u003clabel for=\"can_haul_trailer\" style=\"font-size: 0.85em; color: var(--text-secondary); margin-top: 2px; line-height: 1.4;\"\u003eWilling to haul a trailer (bobtailing).\u003c/label\u003e\n            \u003c/div\u003e\n            \u003cbutton type=\"submit\"\u003eUpdate Truck\u003c/button\u003e\n        \u003c/form\u003e\n    \u003c/section\u003e\n\u003c/div\u003e\n\u003c/body\u003e\n\u003c/html\u003e"}}
